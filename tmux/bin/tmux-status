# ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ

FULL=‚Ėď
EMPTY=‚ĖĎ
EOL=‚Ėí
SIZE=7
C0="#000000"
C1="#222222"
C2="#8FBCBB"
C3="#B3291C"
C4="#3A3A3A"
C5="#efefef"
C6="#878787"
C7="#666666"

draw(){
	perc=$1
	SIZE=$2
	inc=$(( perc * SIZE / 100 ))
	out=
	for v in $(seq 0 $(( SIZE - 1 ))); do
		test "$v" -le "$inc"   \
		&& out="${out}#[fg=$C1]${FULL}" \
		|| out="${out}#[fg=$C1]${EMPTY}"
	done
	echo "$out"
}
temp(){
	t=$(sensors | awk '/Core\ 0/ {gsub(/\+/,"",$3); gsub(/\..+/,"",$3)    ; print $3}')
	tc=$C0
	case 1 in
		$((t <= 50)))
			tc=$C2
			;;
		$((t >= 75)))
			tc=$C3
			;;
	esac
	echo "#[fg=$tc]$t¬įc"
}
`draw $RAM_INFO 4` `temp` `draw $CPU_INFO 7` `vpn` `clock`
